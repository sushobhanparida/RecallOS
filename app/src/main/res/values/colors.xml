<?xml version="1.0" encoding="utf-8"?>
<!--
    Apricot Soft-Touch — XML color resources.
    Used by the Activity theme for status bar, nav bar, and window background.
    Compose UI reads colors directly from the Kotlin Color.kt palette.
-->
<resources>
    <!-- Core palette -->
    <color name="apricot_background">#FFF8F6</color>
    <color name="apricot_primary">#94492E</color>
    <color name="apricot_on_primary">#FFFFFF</color>
    <color name="apricot_surface_container_lowest">#FFFFFF</color>
    <color name="apricot_outline_variant">#DAC1BA</color>
    <color name="apricot_on_surface">#211A18</color>

    <!-- Legacy aliases (kept for any remaining XML references) -->
    <color name="white">#FFFFFFFF</color>
    <color name="black">#FF000000</color>
</resources>
